# Odoo Connection Settings
ODOO_URL=https://odoo.example.com
ODOO_DB=your_database
ODOO_USERNAME=admin
ODOO_PASSWORD=your_api_key_or_password

# Optional: Default timezone for queries (default: Asia/Ho_Chi_Minh)
ODOO_TIMEZONE=Asia/Ho_Chi_Minh

# B4B API Settings (for import CLI)
B4B_API_URL=http://localhost:8000
B4B_TOKEN=your-jwt-token
B4B_ENTITY_ID=your-entity-uuid
